{
  "name": "@ahf/digital-literacy-toolkit",
  "version": "0.1.0",
  "description": "An interactive web application for teaching digital literacy skills, built by Applied Humanity Foundation.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "jsdom": "^24.0.0"
  },
  "author": "Applied Humanity Foundation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/applied-humanity-foundation/digital-literacy-toolkit.git"
  },
  "keywords": [
    "digital-literacy",
    "education",
    "nonprofit",
    "interactive-learning",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
